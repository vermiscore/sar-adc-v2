** === Monotonic CDAC subckt ===
.subckt cdac Vout vdd gnd b3_p b3_n b2_p b2_n b1_p b1_n b0_p b0_n
C1 Vout sw0 1f m=1
C2 Vout sw1 2f m=1
C3 Vout sw2 4f m=1
C4 Vout sw3 8f m=1
XMN0 sw0 b0_n gnd gnd sky130_fd_pr__nfet_01v8 L=0.15 W=1 nf=1 ad='int((nf+1)/2) * W/nf * 0.29' as='int((nf+2)/2) * W/nf * 0.29' pd='2*int((nf+1)/2) * (W/nf + 0.29)' ps='2*int((nf+2)/2) * (W/nf + 0.29)' nrd='0.29 / W' nrs='0.29 / W' sa=0 sb=0 sd=0 mult=1 m=1
